# Supabase project (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Used by the matching engine + dormancy cron. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=
# Shared secret checked by /api/cron/dormancy (set the same value in Vercel cron config)
CRON_SECRET=
